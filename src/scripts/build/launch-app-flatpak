#!/bin/bash

set -euo pipefail

if [ -d build/src/launch-app/build ]; then
	rm -rf build/src/launch-app/build
fi
mkdir -p build/src/launch-app/build
pushd build/src/launch-app/build
	CC=clang CXX=clang++ cmake \
		-DCMAKE_BUILD_TYPE=Release \
		.. \
		-DAPPLICATION_NAME=\"NEVAIL_INTERNAL_APP_NAME\" \
		-DSHOULD_OPEN_IN_DEFAULT_BROWSER=NEVAIL_OPEN_IN_DEFAULT_BROWSER \
		-DSHOULD_RUN_IN_BACKGROUND=NEVAIL_SHOULD_RUN_IN_BACKGROUND

	cmake --build .
	cp launch-app ../../../../launch-app.flatpak
popd

cp launch-app.flatpak NEVAIL_INTERNAL_APP_NAME-linux/NEVAIL_INTERNAL_APP_NAME-linux/launch-app

#!/bin/bash

set -euo pipefail

shopt -s extglob

if [ -d  NEVAIL_INTERNAL_APP_NAME.AppImage ]; then
    rm -r NEVAIL_INTERNAL_APP_NAME.AppImage
fi

cp -r src/packages/appimage/nevail.AppImage NEVAIL_INTERNAL_APP_NAME.AppImage
mv NEVAIL_INTERNAL_APP_NAME.AppImage/nevail.desktop NEVAIL_INTERNAL_APP_NAME.AppImage/NEVAIL_INTERNAL_APP_NAME.desktop
mkdir -p NEVAIL_INTERNAL_APP_NAME.AppImage/usr/lib/NEVAIL_INTERNAL_APP_NAME
tar --strip-components=1 -xvf  datcord-linux-x86_64.tar.@(bz2|xz) -C NEVAIL_INTERNAL_APP_NAME.AppImage/usr/lib/NEVAIL_INTERNAL_APP_NAME/
cp -r src/distribution/ NEVAIL_INTERNAL_APP_NAME.AppImage/usr/lib/NEVAIL_INTERNAL_APP_NAME/
mv NEVAIL_INTERNAL_APP_NAME.AppImage/usr/lib/NEVAIL_INTERNAL_APP_NAME/distribution/policies-linux-appimage.json NEVAIL_INTERNAL_APP_NAME.AppImage/usr/lib/NEVAIL_INTERNAL_APP_NAME/distribution/policies.json
cp src/open-in-default-browser/open-in-default-browser NEVAIL_INTERNAL_APP_NAME.AppImage/usr/lib/NEVAIL_INTERNAL_APP_NAME/

ARCH=x86_64 appimagetool NEVAIL_INTERNAL_APP_NAME.AppImage/

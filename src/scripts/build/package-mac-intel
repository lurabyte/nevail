#!/bin/bash

set -euo pipefail

mkdir "NEVAIL_INTERNAL_APP_NAME-darwin-x86_64/NEVAIL_APP_NAME_STRIPPED.app"
mv NEVAIL_INTERNAL_APP_NAME-darwin-x86_64/Contents "NEVAIL_INTERNAL_APP_NAME-darwin-x86_64/NEVAIL_APP_NAME_STRIPPED.app/"

if [ -f NEVAIL_INTERNAL_APP_NAME-darwin-x86_64.dmg ]; then
    rm NEVAIL_INTERNAL_APP_NAME-darwin-x86_64.dmg
fi
mozilla-unified/mach python -m mozbuild.action.make_dmg NEVAIL_INTERNAL_APP_NAME-darwin-x86_64 NEVAIL_INTERNAL_APP_NAME-darwin-x86_64.dmg --volume-name="NEVAIL_APP_NAME_STRIPPED" --dsstore=src/branding-template/dsstore

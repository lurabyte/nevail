#!/bin/bash

set -euo pipefail

export TARGET=x86_64-linux-gnu
export MOZBUILD=$PWD/.mozbuild

mkdir deb_work
cp -r NEVAIL_INTERNAL_APP_NAME-linux-x86_64 deb_work/NEVAIL_INTERNAL_APP_NAME
cd deb_work
tar -cjf NEVAIL_INTERNAL_APP_NAME-linux-x86_64.tar.bz2 NEVAIL_INTERNAL_APP_NAME
cd ..

cd mozilla-unified

./mach repackage deb \
    -i ../deb_work/NEVAIL_INTERNAL_APP_NAME-linux-x86_64.tar.bz2 \
    -o ../NEVAIL_INTERNAL_APP_NAME-x86_64-NEVAIL_APP_VERSION.deb \
    --arch x86_64 \
    --version NEVAIL_APP_VERSION --build-number 0 \
    --templates ../src/packages/debian \
    --product NEVAIL_INTERNAL_APP_NAME \
    --release-type release

cd ..

rm -rf deb_work

unset TARGET
